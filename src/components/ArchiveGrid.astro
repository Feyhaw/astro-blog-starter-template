---
import ArchiveCard from './ArchiveCard.astro';
import ArchiveModal from './ArchiveModal.astro';

const { items, variant = 'grid', type = 'project' } = Astro.props;
---

<div class:list={['project-grid', { masonry: variant === 'masonry' }]}>
	{
		items.map((item) => (
			<ArchiveCard item={item} type={type}/>
		))
	}
</div>

{
	items.map((item) => (
		<ArchiveModal item={item} type={type}/>
	))
}

<style>
	:global(.project-grid) {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		margin-top: 3rem;
	}

	:global(.project-card) {
		background: rgba(255, 255, 255, 0.55);
		border: 1px solid rgba(93, 126, 145, 0.18);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 12px 30px rgba(93, 126, 145, 0.08);
		cursor: pointer;
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease,
			background 0.25s ease;
	}

	:global(.project-card:hover) {
		transform: scale(1.045);
		box-shadow: 0 18px 45px rgba(93, 126, 145, 0.18);
		background: rgba(255, 255, 255, 0.72);
	}

	:global(.project-card img) {
		width: 100%;
		height: 220px;
		display: block;
		object-fit: cover;
	}

	:global(.project-card p),
	:global(.project-card h3) {
		margin-left: 1rem;
		margin-right: 1rem;
	}

	:global(.project-card p:first-of-type) {
		margin-top: 1rem;
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(93, 126, 145, 0.8);
	}

	:global(.project-card h3) {
		margin-top: 0.5rem;
		margin-bottom: 0.6rem;
		font-size: 1.25rem;
		line-height: 1.25;
		color: rgb(var(--black));
	}

	:global(.project-card p:last-of-type) {
		margin-bottom: 1.3rem;
		font-size: 0.95rem;
		line-height: 1.6;
		color: rgb(var(--gray-dark));
	}

    .project-grid.masonry {
	    column-count: 3;
	    column-gap: 2rem;
	    display: block;
    }

    .project-grid.masonry :global(.project-card) {
	    break-inside: avoid;
	    margin-bottom: 2rem;
    }

    .project-grid.masonry :global(.project-card img) {
	    height: auto;
	    object-fit: contain;
    }

	:global(.project-modal) {
	    width: min(900px, 86vw);
	    height: min(620px, 82vh);
	    border: none;
	    border-radius: 18px;
	    padding: 0;
	    background: rgba(255, 255, 255, 0.86);
	    box-shadow: 0 30px 90px rgba(93, 126, 145, 0.28);
    }

    :global(.project-modal::backdrop) {
	    background: rgba(240, 248, 252, 0.45);
	    backdrop-filter: blur(4px);
    }

    :global(.modal-inner) {
	    display: grid;
	    grid-template-columns: 42% 58%;
	    height: 100%;
    }

    :global(.modal-image) {
	    height: 100%;
	    display: flex;
	    align-items: center;
	    justify-content: center;
	    padding: 1.5rem;
	    overflow: hidden;
    }

    :global(.modal-image img) {
	    width: 100%;
	    height: 100%;
	    object-fit: contain;
    }

    :global(.modal-text) {
	    padding: 2rem;
	    overflow-y: auto;
    }

    :global(.modal-close) {
	    position: absolute;
	    top: 1rem;
	    right: 1rem;
    	border: none;
    	background: transparent;
    	font-size: 1.5rem;
    	cursor: pointer;
    }

    :global(.modal-status) {
    	display: inline-block;
    	margin: 0.5rem 0 1rem;
    	padding: 0.25rem 0.6rem;
    	border: 1px solid rgba(93, 126, 145, 0.25);
    	border-radius: 999px;
    	font-size: 0.72rem;
    	letter-spacing: 0.12em;
    	text-transform: uppercase;
    	color: rgba(93, 126, 145, 0.9);
    }

    :global(.modal-keywords) {
    	display: flex;
    	flex-wrap: wrap;
    	gap: 0.45rem;
    	margin: 0.5rem 0 1.5rem;
    }

    :global(.modal-keywords span) {
    	padding: 0.28rem 0.55rem;
    	border-radius: 999px;
    	background: rgba(93, 126, 145, 0.09);
    	font-size: 0.72rem;
    	letter-spacing: 0.08em;
    	text-transform: uppercase;
    	color: rgba(93, 126, 145, 0.85);
    }

    :global(.modal-text hr) {
    	border: none;
    	height: 1px;
    	background: rgba(93, 126, 145, 0.18);
    	margin: 1.2rem 0;
    }

	@media (max-width: 900px) {
		.project-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
	}

    @media (max-width: 900px) {
	    .project-grid.masonry {
		    column-count: 2;
	    }
    }

    @media (max-width: 600px) {
	    .project-grid.masonry {
	    	column-count: 1;
	    }
    }
</style>

<script>
	document.querySelectorAll('[data-modal]').forEach((button) => {
		button.addEventListener('click', () => {
			const modal = document.getElementById(button.dataset.modal);
			modal?.showModal();
		});
	});

	document.querySelectorAll('.modal-close').forEach((button) => {
		button.addEventListener('click', () => {
			button.closest('dialog')?.close();
		});
	});

	const hash = window.location.hash.slice(1);

	if (hash) {
		const modal = document.getElementById(`project-${hash}`);
		modal?.showModal();
	}
</script>