<canvas id="starfield"></canvas>

<section class="ascii-ocean" aria-hidden="true">
    <div class="icebergs">
        <pre>
                +                     ++
               +++                  ++ +                         ++++
               ++ +                 + +++         ++            ++ +++++
              ++ + +        ++     ++ + +        + +           +++ +++ +++
        ___ _++  ++++_ ___++++____+++++++++_____++ +++_________++++  ++++++____
        </pre>
    </div>

    <div class="wave wave-one">
        <pre>
          +  .+  . .+ o.+ . +  . o.. +   .+  . +  .+.O o. +  .+ o . + . +
            +.  + o+ .   + .+   . +  +  .  + .+  .   +. +
            + o  . +.  + .    +  .+   .O +   + o  . +   +O  . .+ .
        </pre>
    </div>

    <div class="wave wave-two">
        <pre>
              +  . o +.  +.o  O.+   + .   o+. .+  . O.+  .+ . . +.
        + .   .+   . . +   +   .. + .+  . o.+ . +  .  +. .+  .
            +. .+O. + .  .+  +. O . + . +.   .o+   +    ..+ 0.
        </pre>
    </div>

    <div class="shore">
        <div class="sand sand-one"></div>
        <div class="sand sand-two"></div>
        <div class="sand sand-three"></div>
    </div>
</section>

<script>
    const canvas = document.getElementById('starfield');
    const ctx = canvas.getContext('2d');

    let stars = [];

    function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        stars = Array.from({ length: 140 }, () => ({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height * 0.7,
            r: Math.random() * 2 + 0.4,
            speed: Math.random() * 0.28 + 0.05,
            alpha: Math.random() * 0.35 + 0.12,
        }));
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        stars.forEach((star) => {
            star.y += star.speed;
            if (star.y > canvas.height * 0.75) {
                star.y = -10;
                star.x = Math.random() * canvas.width;
            }

            ctx.beginPath();
            ctx.arc(star.x, star.y, star.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(93, 126, 145, ${star.alpha})`;
            ctx.fill();
            });

        requestAnimationFrame(draw);
    }

    resize();
    draw();

    window.addEventListener('resize', resize);
</script>

<style>

    #starfield {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
    }

    .ascii-ocean {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        height: 48vh;
        z-index: 5;
        overflow: hidden;
        pointer-events: none;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }

    .icebergs {
        position: absolute;
        transform: translateX(10%);
        left: 0;
        right: 0;
        top: 25%;
        opacity: 0.3;
        font-size: clamp(0.45rem, 0.8vw, 0.75rem);
        line-height: 0.85;
        color: rgba(93, 126, 145, 0.55);
    }

    .wave {
        position: absolute;
        left: -10%;
        width: 120%;
        color: rgba(93, 126, 145, 0.65);
    }

    .wave pre {
        margin: 0;
        font-size: clamp(0.8rem, 1.4vw, 1.25rem);
        line-height: 1.1;
        letter-spacing: 0.35em;
        white-space: pre;
    }

    .wave-one {
        top: 38%;
        animation: waveDrift 16s ease-in-out infinite;
    }

    .wave-two {
        top: 52%;
        opacity: 0.42;
        animation: waveDriftReverse 23s ease-in-out infinite;
    }

    .shore {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 36%;
        z-index: -1;
        background: linear-gradient(
        to bottom,
        rgba(214, 229, 236, 0.05),
        rgba(93, 126, 145, 0.18)
        );
    }

    .sand {
        position: absolute;
        left: -10%;
        width: 120%;
        height: 80%;
        border-radius: 50% 50% 0 0;
        background: rgba(93, 126, 145, 0.08);
    }

    .sand-one {
        bottom: -35%;
        animation: shoreWash 18s ease-in-out infinite;
    }

    .sand-two {
        bottom: -45%;
        opacity: 0.7;
        animation: shoreWash 24s ease-in-out infinite reverse;
        }

    .sand-three {
        bottom: -55%;
        opacity: 0.45;
        animation: shoreWash 32s ease-in-out infinite;
    }

    @keyframes waveDrift {
        from {
            transform: translateX(0) translateY(0);
        }
        50% {
            transform: translateX(8%) translateY(8px);
        }
        to {
            transform: translateX(0) translateY(0);
        }
    }

    @keyframes waveDriftReverse {
        from {
            transform: translateX(0) translateY(0);
        }
        50% {
            transform: translateX(-7%) translateY(-6px);
        }
        to {
        transform: translateX(0) translateY(0);
        }
    }

    @keyframes shoreWash {
        0% {
            transform: translateY(12px) scaleX(1);
        }
        50% {
            transform: translateY(-18px) scaleX(1.04);
        }
        100% {
            transform: translateY(12px) scaleX(1);
        }
    }

</style>
