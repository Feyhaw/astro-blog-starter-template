---
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
	</nav>
</header>

<style>
	header {
  		position: fixed;
  		top: 0.5rem;
		left: 0.75rem;
  		z-index: 60;
  		margin: 0;
  		padding: 0;
  		background: transparent;
  		box-shadow: none;
	}

	h2 {
  		margin: 0;
  		font-size: 1em;
  		letter-spacing: 0.12em;
  		text-transform: uppercase;
	}

	h2 a,
	h2 a.active {
  		color: rgb(var(--black));
  		text-decoration: none;
	}

    nav {
		display: block;
	}

</style>