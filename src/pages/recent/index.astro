---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import BreathingBackG from '../../components/BreathingBackG.astro';
import EdgeNav from '../../components/EdgeNav.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const constitution = (await getCollection('constitution')).sort(
	(a, b) => a.data.title.localeCompare(b.data.title)
);

const posts = (await getCollection('recent')).sort((a, b) => {
	if (a.data.pinned && !b.data.pinned) return -1;
	if (!a.data.pinned && b.data.pinned) return 1;

	return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={"Recent | " + SITE_TITLE} description="Latest updates" />
		<style>
			main {
				width: min(860px, calc(100% - 2rem));
			}
			
			.constitution {
    			margin-bottom: 3rem;
			}

			.constitution h2 {
    			margin-bottom: .4rem;
			}

			.constitution-card {
    			padding: 1.2rem 0;
    			border-top: 1px solid rgba(93,126,145,.18);
    			border-bottom: 1px solid rgba(93,126,145,.18);
			}

			.constitution-card a{
    			text-decoration:none;
    			color:inherit;
			}

			.log-intro {
				margin-top:4rem 
				margin-bottom: 2rem;
			}

			.log-intro p {
				color: rgb(var(--gray));
				line-height: 1.7;
			}

			.log-list {
				display: grid;
				gap: 0;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.log-entry {
				border-top: 1px solid rgba(93, 126, 145, 0.22);
				padding: 1.4rem 0;
			}

			.log-entry:last-child {
				border-bottom: 1px solid rgba(93, 126, 145, 0.22);
			}

			.log-entry a {
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 1.5rem;
				text-decoration: none;
				color: inherit;
			}

			.log-title {
				margin: 0 0 0.55rem;
				font-size: 1.15rem;
				line-height: 1.3;
				color: rgb(var(--black));
			}

			.log-description {
				margin: 0;
				max-width: 560px;
				line-height: 1.65;
				color: rgb(var(--gray-dark));
			}

			.log-date {
				margin: 0;
				white-space: nowrap;
				font-size: 0.82rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
			}

			.log-entry a:hover .log-title,
			.log-entry a:hover .log-date {
				color: rgb(var(--accent));
			}

			@media (max-width: 720px) {
				.log-entry a {
					grid-template-columns: 1fr;
					gap: 0.6rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<BreathingBackG transition:name="site-background" />
		<EdgeNav />
		<main>			
			<section>
				<div class="log-intro">
					<h1>Archive Log</h1>
					<p>
					Recent progress and inspirations.
					</p>
				</div>

				<section class="constitution">
    				{
        			constitution.map((doc) => (
            			<article class="constitution-card">

                				<a href={`/constitution/${doc.id}/`}>

    			                	<h5>{doc.data.title}</h5>

                			    	<p>{doc.data.description}</p>

        			        	</a>

            				</article>
        				))
    				}
				</section>

				<ul class="log-list">
					{
						posts.map((post) => (
							<li class="log-entry">
								<a href={`/recent/${post.id}/`}>
									<div>
										<h2 class="log-title">{post.data.title}</h2>
										<p class="log-description">{post.data.description}</p>
									</div>

									<p class="log-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
	</body>
</html>
