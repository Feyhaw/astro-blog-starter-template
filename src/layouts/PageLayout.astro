---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import BreathingBackG from '../components/BreathingBackG.astro';
import EdgeNav from '../components/EdgeNav.astro';

const { title, description } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header transition:name="site-header" />
		<BreathingBackG transition:name="site-background" />
		<EdgeNav />

		<main>
			<section class="page">
				<slot />
			</section>
		</main>
	</body>
</html>

<style>
	main {
		position: relative;
		z-index: 20;
		width: 100%;
		min-height: 100vh;
	}

	:global(.shortcut) {
		text-decoration: none;
		color: rgb(var(--accent));
		border-bottom: 1px solid rgba(var(--accent), 0.25);
		transition:
			border-color 0.2s ease,
			opacity 0.2s ease;
	}

	:global(.shortcut:hover) {
		border-bottom-color: rgb(var(--accent));
		opacity: 0.75;
	}

	.page {
		width: 960px;
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 7rem 1rem 6rem;
		color: rgb(var(--gray-dark));
	}

	.page h1 {
		text-align: center;
		margin-bottom: 3rem;
	}

	.page p {
		line-height: 1.8;
		margin-bottom: 1.2rem;
	}

	@media (max-width: 720px) {
		.page {
			padding-top: 6rem;
		}
	}
</style>